# ──────────────────────────────────────────
#  SERVER
# ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────
#  MONGODB
# ──────────────────────────────────────────
# Local:  mongodb://localhost:27017/classroom_db
# Docker: mongodb://mongodb:27017/classroom_db
MONGODB_URI=mongodb://localhost:27017/classroom_db

# ──────────────────────────────────────────
#  JWT
# ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────
#  AI MICROSERVICE
# ──────────────────────────────────────────
# Local:  http://localhost:8000
# Docker: http://ai_service:8000
AI_SERVICE_URL=http://localhost:8000

# ──────────────────────────────────────────
#  FILE UPLOAD
# ──────────────────────────────────────────
MAX_VIDEO_SIZE_MB=500
UPLOAD_DIR=uploads

# ──────────────────────────────────────────
#  ENGAGEMENT
# ──────────────────────────────────────────
ENGAGEMENT_THRESHOLD=70

# ──────────────────────────────────────────
#  CORS
# ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173
