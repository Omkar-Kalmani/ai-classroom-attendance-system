# ──────────────────────────────────────────
#  AI SERVICE SETTINGS
# ──────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# How many frames per second to analyze
# Lower = faster processing, less accurate
# Higher = slower processing, more accurate
# Recommended: 5 (good balance)
PROCESSING_FPS=5

# Frame score threshold — a frame is "attentive" if score >= this
# Range: 0.0 to 1.0
FRAME_SCORE_THRESHOLD=0.6

# Default engagement threshold for attendance
# Student is PRESENT if engagement_score >= this
ENGAGEMENT_THRESHOLD=70

# Node.js backend URL (for internal communication)
NODE_BACKEND_URL=http://localhost:5000
